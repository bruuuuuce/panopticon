{
  "id": "db-overview",
  "title": "Database Overview",
  "description": "What's in the datasource itself: tables, row counts and schema, read straight from information_schema.",
  "accentColor": "#3987e5",
  "gridColumns": 12,
  "rotation": { "durationSeconds": 20, "enabled": true },
  "panels": [
    {
      "id": "kpi-total-tables",
      "title": "Tables",
      "type": "stat",
      "dataRef": "db-kpi-total-tables",
      "grid": { "row": 1, "col": 1, "rowSpan": 1, "colSpan": 3 },
      "refresh": { "intervalSeconds": 60, "enabled": true },
      "options": { "valueField": "total_tables", "format": "number" }
    },
    {
      "id": "kpi-total-rows",
      "title": "Total Rows",
      "type": "stat",
      "dataRef": "db-kpi-total-rows",
      "grid": { "row": 1, "col": 4, "rowSpan": 1, "colSpan": 3 },
      "refresh": { "intervalSeconds": 60, "enabled": true },
      "options": { "valueField": "total_rows", "format": "number" }
    },
    {
      "id": "donut-table-inventory",
      "title": "Row Distribution",
      "type": "donut",
      "dataRef": "db-table-inventory",
      "grid": { "row": 1, "col": 7, "rowSpan": 2, "colSpan": 3 },
      "refresh": { "intervalSeconds": 60, "enabled": true },
      "options": { "labelField": "table_name", "valueField": "row_count" }
    },
    {
      "id": "bar-table-inventory",
      "title": "Rows by Table",
      "type": "bar",
      "dataRef": "db-table-inventory",
      "grid": { "row": 1, "col": 10, "rowSpan": 2, "colSpan": 3 },
      "refresh": { "intervalSeconds": 60, "enabled": true },
      "options": { "xField": "table_name", "yField": "row_count", "seriesName": "Rows" }
    },
    {
      "id": "table-column-inventory",
      "title": "Column Inventory",
      "type": "table",
      "dataRef": "db-column-inventory",
      "grid": { "row": 2, "col": 1, "rowSpan": 1, "colSpan": 6 },
      "refresh": { "intervalSeconds": 60, "enabled": true },
      "options": {
        "columns": ["table_name", "column_name", "data_type"]
      }
    }
  ]
}
